# ============================================
# Fløøxy's Community - Configuration Template
# ============================================
# Copiez ce fichier vers .env et configurez vos valeurs

# ---- Serveur ----
PORT=3000
NODE_ENV=development

# ---- Sécurité JWT ----
# ⚠️ IMPORTANT: Générez une clé forte pour production!
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_NOW
JWT_EXPIRATION=7d

# ---- Base de Données ----
DB_PATH=./data/users.json
BACKUP_PATH=./data/backup

# ---- Sécurité des Mots de Passe ----
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=15

# ---- CORS (Origines Autorisées) ----
# Séparez les URL par des virgules
CORS_ORIGIN=http://localhost:3000,http://localhost:5000,http://127.0.0.1:5500

# ---- Email (Optionnel pour notifications) ----
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ---- Logs ----
LOG_LEVEL=debug
LOG_FILE=./logs/app.log
